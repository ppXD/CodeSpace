<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>CodeSpace.Core</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.DataProtection.EntityFrameworkCore" Version="10.0.*" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.0.*" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" Version="10.0.*" />
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" Version="10.6.0" />
    <PackageReference Include="NGitLab" Version="11.7.0" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.0.*" />
    <PackageReference Include="EFCore.NamingConventions" Version="10.0.*" />

    <PackageReference Include="Autofac" Version="8.*" />
    <PackageReference Include="Autofac.Extensions.DependencyInjection" Version="10.*" />

    <PackageReference Include="MediatR" Version="12.*" />
    <PackageReference Include="MediatR.Extensions.Autofac.DependencyInjection" Version="12.*" />
    <PackageReference Include="Octokit" Version="14.0.0" />

    <PackageReference Include="Serilog" Version="4.*" />

    <PackageReference Include="Hangfire" Version="1.8.*" />
    <PackageReference Include="Cronos" Version="0.8.*" />

    <!-- Transitive-vuln pin: Hangfire 1.8 floors Newtonsoft.Json at 11.0.1, which has a high-severity
         deep-nesting DoS (GHSA-5crp-9r3c-p9vr). Hangfire runs on 13.x; pin the patched version (the rest
         of the tree already resolves 13.0.3). The codebase itself uses System.Text.Json, not Newtonsoft. -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />

    <PackageReference Include="dbup-core" Version="6.0.*" />
    <PackageReference Include="dbup-postgresql" Version="6.0.*" />
    <PackageReference Include="System.IdentityModel.Tokens.Jwt" Version="8.5.0" />
    <PackageReference Include="YamlDotNet" Version="16.*" />
  </ItemGroup>

  <ItemGroup Label="DbUp">
    <Content Include="Persistence\DbUpFiles\**" Exclude="Persistence\DbUpFiles\*.cs">
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CodeSpace.Messages\CodeSpace.Messages.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Expose `internal` members to the unit-test project so defensive helpers like
         WorkflowJsonSafeParse can be tested without resorting to reflection. -->
    <InternalsVisibleTo Include="CodeSpace.UnitTests" />
    <!-- The integration test reaches internal executor helpers (e.g. IsMcpEndpointEnabled) to prove the
         executor-owned MCP endpoint lifecycle through the real ExecuteAsync path. -->
    <InternalsVisibleTo Include="CodeSpace.IntegrationTests" />
    <!-- The gated real-CLI E2E drives the production harness + runner internals (WriteConfigHomeFiles,
         ClaudeTranscriptPath) against the real claude binary's filesystem contract. -->
    <InternalsVisibleTo Include="CodeSpace.E2ETests" />
  </ItemGroup>

</Project>

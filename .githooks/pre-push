#!/usr/bin/env bash
# Block direct pushes to main. All changes must go through a PR.
#
# Bypass (rare, e.g. fixing the protection itself): export ALLOW_MAIN_PUSH=1
# Bypass for one push: git push --no-verify origin main

remote="$1"
url="$2"

while read -r local_ref local_sha remote_ref remote_sha; do
    case "$remote_ref" in
        refs/heads/main)
            if [ "${ALLOW_MAIN_PUSH:-0}" != "1" ]; then
                echo "❌  Direct push to main is blocked."
                echo ""
                echo "    Open a PR instead:"
                echo "      git switch -c feat/your-change"
                echo "      git push -u origin feat/your-change"
                echo "      gh pr create --base main --fill"
                echo ""
                echo "    To override (rare): ALLOW_MAIN_PUSH=1 git push origin main"
                exit 1
            fi
            ;;
    esac
done

exit 0
